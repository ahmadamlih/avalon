{
  "rules": {
    "rooms": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null",

        "teamVotes": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid",
            ".read": false
          },
          ".read": false
        },

        "missionVotes": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid",
            ".read": false
          },
          ".read": false
        }
      }
    },

    "secrets": {
      "$code": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null"
        }
      }
    },

    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid"
      }
    }
  }
}
